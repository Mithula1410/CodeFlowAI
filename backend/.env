# CodeFlow AI - Configuration Environment Variables (Local Dev)
PROJECT_NAME="CodeFlow AI"
DEBUG=true
VERSION="1.0.0"
API_V1_STR="/api/v1"
HOST="0.0.0.0"
PORT=8000
BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:3000,http://127.0.0.1:5173"

SECRET_KEY="codeflow_dev_secret_key_change_me_in_production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=120
REFRESH_TOKEN_EXPIRE_DAYS=7

# Local SQLite Database
DATABASE_URL="sqlite:///./codeflow.db"

# Redis Config (will fallback to BackgroundTasks if Redis is down)
REDIS_URL="redis://localhost:6379/0"

# AI Key Configs (Mock by default)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
CLAUDE_API_KEY=""
DEFAULT_AI_PROVIDER="mock"
DEFAULT_AI_MODEL="mock-model"

GITHUB_CLIENT_ID="github_client_id_placeholder"
GITHUB_CLIENT_SECRET="github_client_secret_placeholder"
GITHUB_REDIRECT_URI="http://localhost:5173/github/callback"

RATE_LIMIT_REQUESTS=1000
RATE_LIMIT_WINDOW_SECONDS=60
