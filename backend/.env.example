# CodeFlow AI - Configuration Environment Variables

# App Config
PROJECT_NAME="CodeFlow AI"
DEBUG=true
VERSION="1.0.0"
API_V1_STR="/api/v1"

# Server Host Config
HOST="0.0.0.0"
PORT=8000

# CORS settings (comma-separated list of allowed origins)
BACKEND_CORS_ORIGINS="http://localhost:5173,http://localhost:3000"

# Security & JWT
# You can generate a secret using: openssl rand -hex 32
SECRET_KEY="replace-this-with-a-very-secure-random-secret-key-for-production"
ALGORITHM="HS256"
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Database Connection (PostgreSQL or SQLite fallback for local testing)
# Example PostgreSQL: postgresql://postgres:postgres@localhost:5432/codeflow
# Example SQLite: sqlite:///./codeflow.db
DATABASE_URL="sqlite:///./codeflow.db"

# Background Worker & Cache (Redis)
# If empty or unreachable, background tasks will fallback to FastAPI BackgroundTasks
REDIS_URL="redis://localhost:6379/0"

# AI Provider API Keys (Leave empty to use Mock AI service for testing)
GEMINI_API_KEY=""
OPENAI_API_KEY=""
CLAUDE_API_KEY=""

# Dynamic AI Configuration defaults
DEFAULT_AI_PROVIDER="mock"  # "gemini" | "openai" | "claude" | "mock"
DEFAULT_AI_MODEL="mock-model"

# GitHub Integration
GITHUB_CLIENT_ID="github_client_id_placeholder"
GITHUB_CLIENT_SECRET="github_client_secret_placeholder"
GITHUB_REDIRECT_URI="http://localhost:5173/github/callback"

# Rate Limiting
RATE_LIMIT_REQUESTS=100
RATE_LIMIT_WINDOW_SECONDS=60
